{
  "name": "formics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "gen:barrels": "barrelsby -d src/components -l all -s flat --delete && barrelsby -d src/hooks -l all -s flat --delete && barrelsby -d src/constants -l all -s flat --delete && barrelsby -d src/layouts -l all -s flat --delete && barrelsby -d src/pages -l all -s flat --delete"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@types/react-i18next": "^7.8.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "barrelsby": "^2.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@reduxjs/toolkit": "^2.6.1",
    "axios": "^1.8.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.4.1",
    "sass": "^1.86.3"
  }
}
